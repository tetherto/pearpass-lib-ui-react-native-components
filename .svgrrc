{
  "icon": true,
  "typescript": true,
  "replaceAttrValues": {
    "#000": "currentColor",
    "#000000": "currentColor",
    "#fff": "currentColor",
    "#ffffff": "currentColor",
    "white": "currentColor"
  },
  "svgoConfig": {
    "plugins": [
      {
        "name": "preset-default"
      },
      "removeXMLNS"
    ]
  }
}
